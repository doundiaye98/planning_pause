# Copier vers .env ou exporter dans systemd / Docker / hébergeur.
# Ne pas committer de vrai .env avec des secrets.

# --- Obligatoire en production ---
# ENV=production
# SESSION_SECRET=remplacer-par-une-chaine-longue-aleatoire

# --- Cookies session (HTTPS requis si Secure) ---
# SESSION_COOKIE_SECURE=true
# SESSION_MAX_AGE_SECONDS=604800

# --- Base (défaut : fichier local SQLite) ---
# SQLALCHEMY_DATABASE_URL=sqlite:///./pause_entreprise.db

# --- Si le navigateur appelle l’API depuis une autre origine (ex. front sur un autre sous-domaine) ---
# CORS_ORIGIN_REGEX=https?://(www\.)?votredomaine\.example
